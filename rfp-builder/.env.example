# ===========================================
# Tendr Frontend Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# --- API ---
REACT_APP_API_URL=http://localhost:3001

# --- WorkOS AuthKit (client-side) ---
REACT_APP_WORKOS_CLIENT_ID=client_xxxxxxxxxx
REACT_APP_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Sentry (error tracking) ---
REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
