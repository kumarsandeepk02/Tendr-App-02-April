# ===========================================
# Tendr Server Environment Variables
# Copy this to .env and fill in your values
# ===========================================

# --- Existing (keep your current values) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
PORT=3001
FRONTEND_URL=http://localhost:3000
CLAUDE_DEFAULT_MODEL=sonnet

# --- Neon Database ---
DATABASE_URL=postgresql://user:password@ep-xxx-xxx-123456.us-east-2.aws.neon.tech/tendr?sslmode=require

# --- WorkOS Auth ---
WORKOS_API_KEY=sk_test_xxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxx
WORKOS_REDIRECT_URI=http://localhost:3001/api/auth/callback
WORKOS_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# --- AWS S3 (file uploads) ---
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=tendr-uploads

# --- Upstash Redis (rate limiting + caching) ---
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# --- Sentry (error tracking) ---
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- App ---
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Dev Auth (REMOVE in production) ---
# Set to "true" to allow dev auth bypass (localhost only)
# ALLOW_DEV_AUTH_BYPASS=true
